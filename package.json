{
  "name": "iobroker.questdb",
  "version": "0.3.5",
  "description": "Stores ioBroker state history in a QuestDB time-series database. Each enabled datapoint gets its own QuestDB table, written via the InfluxDB Line Protocol (ILP) over HTTP, HTTPS, or TCP.",
  "author": {
    "name": "pva2007",
    "email": "github@valicek.de"
  },
  "contributors": [],
  "homepage": "https://github.com/pva2007/ioBroker.questdb",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "time-series",
    "questdb",
    "iot",
    "timeseries",
    "history",
    "storage"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pva2007/ioBroker.questdb.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "@questdb/nodejs-client": "^4.2.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.0",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^20.19.41",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "main": "index.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "index.js",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test:ts": "mocha",
    "test:unit": "mocha",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server"
  },
  "bugs": {
    "url": "https://github.com/pva2007/ioBroker.questdb/issues"
  },
  "readmeFilename": "README.md"
}
